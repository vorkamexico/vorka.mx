
<!doctype html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Propuesta — Carmen Jamaica · Vorka México</title>
<meta name="description" content="Propuesta de acompañamiento estratégico y de contenido para Carmen Jamaica, Regidora del H. Ayuntamiento de Celaya 2024–2027 (Movimiento Ciudadano). Vorka México · Ago 2026 – Ago 2027." />
<meta name="theme-color" content="#FBFAF8" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#15140F" media="(prefers-color-scheme: dark)" />
<link rel="icon" type="image/png" href="LOGO.png" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Mona+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,500;1,700;1,800&family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500;1,600&display=swap" rel="stylesheet" />

<style>
  /* ============================== Logo asset ============================== */
  :root{
    --logo-data: url("data:image/png;base64,");
    --logo-filter: none;
  }

  /* ============================== Tokens ============================== */
  :root{
    --paper:#FBFAF8;
    --paper-2:#F4F1EA;
    --ink:#141414;
    --ink-2:rgba(20,20,20,0.66);
    --ink-3:rgba(20,20,20,0.40);
    --ink-4:rgba(20,20,20,0.18);
    --line:rgba(20,20,20,0.12);
    --line-strong:rgba(20,20,20,0.30);
    --accent:#1E4438;
    --accent-soft:#2C5849;
    --accent-hover:#163328;
    --accent-mc:#F26522;
    --accent-mc-soft:#D6551C;
    --on-accent:#FBFAF8;
    --field:rgba(20,20,20,0.04);
    --field-focus:rgba(30,68,56,0.07);
    --invert-section:#15140F;
    --invert-ink:#E8E4D8;
    --invert-ink-2:rgba(232,228,216,0.66);
    --invert-line:rgba(232,228,216,0.16);
    --invert-accent:#7DB39C;
    --invert-accent-mc:#FF8845;
  }
  @media (prefers-color-scheme: dark){
    :root{
      --paper:#15140F;
      --paper-2:#1B1A14;
      --ink:#E8E4D8;
      --ink-2:rgba(232,228,216,0.66);
      --ink-3:rgba(232,228,216,0.40);
      --ink-4:rgba(232,228,216,0.18);
      --line:rgba(232,228,216,0.14);
      --line-strong:rgba(232,228,216,0.30);
      --accent:#7DB39C;
      --accent-soft:#9BC8B3;
      --accent-hover:#9BC8B3;
      --accent-mc:#FF8845;
      --accent-mc-soft:#FF9F63;
      --on-accent:#15140F;
      --field:rgba(232,228,216,0.05);
      --field-focus:rgba(125,179,156,0.08);
      --logo-filter:invert(0.92) brightness(1.06);
    }
  }

  /* ============================== Reset ============================== */
  *,*::before,*::after{box-sizing:border-box}
  html,body{margin:0;padding:0;background:var(--paper);color:var(--ink)}
  html{-webkit-text-size-adjust:100%;text-rendering:optimizeLegibility;font-family:'Mona Sans',ui-sans-serif,system-ui,sans-serif}
  body{
    font-family:'Mona Sans',ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,sans-serif;
    font-size:16px;line-height:1.6;font-weight:400;overflow-x:hidden;
  }
  img,svg{max-width:100%;display:block}
  a{color:inherit;text-decoration:none}
  button{background:none;border:0;cursor:pointer;padding:0;font:inherit;color:inherit}
  ::selection{background:var(--accent);color:var(--on-accent)}

  /* ============================== Type ============================== */
  .display{
    font-family:'Mona Sans',ui-sans-serif,system-ui,sans-serif;
    font-weight:800;letter-spacing:-0.025em;line-height:0.96;color:var(--ink);
  }
  .display-serif{
    font-family:'Cormorant Garamond','EB Garamond',Georgia,serif;
    font-weight:500;letter-spacing:-0.01em;line-height:1.04;color:var(--ink);
  }
  .display-serif em{font-style:italic;color:var(--accent);font-weight:500}
  .ital{font-style:italic;color:var(--accent);font-weight:800}
  .ital-mc{font-style:italic;color:var(--accent-mc);font-weight:800}
  .smallcaps{
    text-transform:uppercase;letter-spacing:0.16em;font-size:12px;font-weight:500;color:var(--ink-2);
  }
  .smallcaps-accent{
    text-transform:uppercase;letter-spacing:0.18em;font-size:12px;font-weight:600;color:var(--accent);
    display:inline-flex;align-items:center;gap:14px;
  }
  .smallcaps-accent::before{
    content:"";display:inline-block;width:24px;height:1px;background:var(--accent);
  }
  .smallcaps-mc{
    text-transform:uppercase;letter-spacing:0.18em;font-size:12px;font-weight:600;color:var(--accent-mc);
    display:inline-flex;align-items:center;gap:14px;
  }
  .smallcaps-mc::before{
    content:"";display:inline-block;width:24px;height:1px;background:var(--accent-mc);
  }
  .lead{font-size:clamp(18px,1.5vw,22px);line-height:1.55;color:var(--ink-2);max-width:60ch}

  /* ============================== Shell ============================== */
  .shell{
    width:100%;
    padding-left:clamp(24px,5vw,80px);
    padding-right:clamp(24px,7vw,128px);
    max-width:1520px;
    margin-inline:auto;
  }

  /* ============================== Logo marks (background image) ============================== */
  .brand-mark{
    display:inline-block;height:38px;width:30px;
    background:var(--logo-data) center/contain no-repeat;
    filter:var(--logo-filter);
  }
  .hero-mark{
    display:block;justify-self:end;align-self:end;
    width:100%;max-width:260px;aspect-ratio:1080/1350;
    background:var(--logo-data) center/contain no-repeat;
    filter:var(--logo-filter);
  }
  .foot-mark{
    display:inline-block;height:96px;width:76px;
    background:var(--logo-data) center/contain no-repeat;
    filter:var(--logo-filter);
  }

  /* ============================== Topbar ============================== */
  .topbar{
    position:sticky;top:0;z-index:30;
    background:color-mix(in srgb,var(--paper) 92%,transparent);
    backdrop-filter:saturate(140%) blur(8px);
    -webkit-backdrop-filter:saturate(140%) blur(8px);
    border-bottom:1px solid var(--line);
  }
  .topbar-inner{
    display:flex;align-items:center;justify-content:space-between;
    padding-block:16px;
  }
  .brand{display:flex;align-items:center;gap:14px}
  .brand-name{
    font-family:'Mona Sans',sans-serif;font-weight:800;letter-spacing:-0.01em;
    font-size:18px;color:var(--ink);
  }
  .brand-name span{color:var(--ink-3);font-weight:500}
  .topbar nav{display:flex;gap:28px;align-items:center}
  .topbar nav a{
    font-size:14px;color:var(--ink-2);font-weight:500;
    padding:8px 0;border-bottom:1px solid transparent;transition:color .15s,border-color .15s;
  }
  .topbar nav a:hover{color:var(--ink);border-color:var(--ink)}
  .topbar nav .pill{
    background:var(--ink);color:var(--paper);
    padding:11px 20px;font-size:14px;font-weight:500;
  }
  .topbar nav .pill:hover{background:var(--accent);color:var(--on-accent)}
  @media (max-width:900px){.topbar nav a:not(.pill){display:none}}

  /* ============================== Cover (hero) ============================== */
  .hero{
    padding-top:clamp(80px,12vh,160px);
    padding-bottom:clamp(120px,18vh,220px);
    position:relative;border-bottom:1px solid var(--line);
  }
  .hero-grid{
    display:grid;
    grid-template-columns:minmax(0,1fr) minmax(0,0.42fr);
    gap:clamp(40px,5vw,96px);align-items:end;
  }
  .hero-eyebrow{margin-bottom:32px}
  .hero-title{
    font-size:clamp(44px,6.8vw,116px);
    max-width:16ch;
  }
  .hero-sub{
    margin-top:clamp(28px,3.5vh,48px);
    font-size:clamp(18px,1.4vw,21px);
    line-height:1.55;color:var(--ink-2);
    max-width:58ch;
  }
  .hero-meta{
    margin-top:clamp(40px,5vh,64px);
    display:flex;flex-wrap:wrap;gap:14px;align-items:center;
  }
  .btn-primary{
    background:var(--ink);color:var(--paper);
    padding:18px 32px;font-size:15px;font-weight:500;letter-spacing:0.01em;
    border-radius:0;transition:background .15s,color .15s;
    display:inline-flex;align-items:center;gap:10px;
  }
  .btn-primary:hover{background:var(--accent);color:var(--on-accent)}
  .btn-ghost{
    color:var(--ink);padding:18px 10px;font-size:15px;font-weight:500;
    border-bottom:1px solid var(--ink);transition:color .15s,border-color .15s;
  }
  .btn-ghost:hover{color:var(--accent);border-color:var(--accent)}
  @media (max-width:900px){
    .hero-grid{grid-template-columns:1fr;gap:48px}
    .hero-mark{justify-self:start;max-width:120px;order:-1}
  }

  /* ============================== Meta card (portada) ============================== */
  .cover-meta{
    margin-top:clamp(64px,8vh,96px);
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr));
    gap:clamp(24px,3vw,56px);
    padding-top:clamp(32px,4vh,48px);
    border-top:1px solid var(--line-strong);
  }
  .cover-meta dt{
    font-size:12px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;
    color:var(--ink-3);margin-bottom:8px;
  }
  .cover-meta dd{
    margin:0;font-family:'Mona Sans',sans-serif;font-weight:800;
    font-size:clamp(15px,1.05vw,17px);letter-spacing:-0.005em;line-height:1.3;color:var(--ink);
  }
  .cover-meta dd em{font-style:italic;color:var(--accent-mc);font-weight:800}
  @media (max-width:780px){.cover-meta{grid-template-columns:repeat(2,1fr);gap:32px 24px}}

  /* ============================== Section base ============================== */
  section{padding-block:clamp(96px,14vh,168px);border-bottom:1px solid var(--line)}
  .section-head{
    display:grid;
    grid-template-columns:minmax(0,0.36fr) minmax(0,1fr);
    gap:clamp(40px,5vw,96px);align-items:start;
    margin-bottom:clamp(56px,9vh,112px);
  }
  .section-head .head-rail{padding-top:8px}
  .section-head h2{
    font-family:'Mona Sans',sans-serif;font-weight:800;
    font-size:clamp(38px,5vw,74px);letter-spacing:-0.02em;line-height:1.02;
    margin:0 0 28px;max-width:20ch;text-wrap:balance;
  }
  .section-head .lead{margin-top:0}
  @media (max-width:900px){.section-head{grid-template-columns:1fr;gap:24px}}

  /* ============================== Sobre esta propuesta ============================== */
  .about-quote{
    padding-block:clamp(96px,14vh,180px);
    background:var(--paper);border-bottom:1px solid var(--line);
  }
  .about-head{
    text-align:center;margin-bottom:clamp(32px,5vh,64px);
    display:flex;flex-direction:column;align-items:center;gap:24px;
  }
  .about-head h3{
    font-family:'Cormorant Garamond',serif;font-weight:500;
    font-size:clamp(30px,3.6vw,52px);letter-spacing:-0.005em;line-height:1.18;
    margin:0;max-width:44ch;color:var(--ink);text-wrap:balance;
  }
  .about-head h3 em{font-style:italic;color:var(--accent);font-weight:500}
  .about-head h3 .mc{font-style:italic;color:var(--accent-mc);font-weight:500}

  /* ============================== Perfil ============================== */
  .profile-grid{
    display:grid;
    grid-template-columns:minmax(0,0.42fr) minmax(0,1fr);
    gap:clamp(40px,5vw,88px);align-items:start;
  }
  .profile-photo{
    margin:0;position:relative;overflow:hidden;
    aspect-ratio:1080/1350;background:var(--paper-2);
    border-top:3px solid var(--accent-mc);
  }
  .profile-photo img{
    width:100%;height:100%;object-fit:cover;object-position:center 22%;display:block;
  }
  .profile-photo figcaption{
    position:absolute;left:0;right:0;bottom:0;
    padding:14px 18px;
    background:linear-gradient(to top,rgba(21,20,15,0.72),rgba(21,20,15,0));
    color:#E8E4D8;font-size:12px;letter-spacing:0.12em;
    text-transform:uppercase;font-weight:600;
  }
  .profile-body p{
    font-size:clamp(16px,1.2vw,19px);
    line-height:1.6;color:var(--ink);
    margin:0 0 20px;max-width:52ch;
  }
  .profile-body p + p{color:var(--ink-2)}
  .profile-social-head{
    margin-top:clamp(36px,5vh,56px);
    padding-top:clamp(24px,3vh,32px);
    border-top:1px solid var(--line);
    margin-bottom:20px;
    display:flex;justify-content:space-between;align-items:baseline;
    gap:16px;flex-wrap:wrap;
  }
  .profile-social-head .smallcaps{color:var(--ink-2)}
  .profile-social-head .baseline-note{
    font-size:12px;color:var(--ink-3);letter-spacing:0.02em;
  }
  .social-grid{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:clamp(12px,1.5vw,20px);
  }
  .social-card{
    display:flex;flex-direction:column;gap:14px;
    padding:22px 20px;
    background:var(--field);
    transition:background .15s;
    border-top:2px solid transparent;
    text-decoration:none;
  }
  .social-card:hover{background:var(--field-focus);border-top-color:var(--accent-mc)}
  .social-card .s-head{display:flex;align-items:center;gap:10px}
  .social-card .s-icon{
    width:18px;height:18px;color:var(--ink);flex-shrink:0;
  }
  .social-card .s-net{
    font-size:11px;letter-spacing:0.14em;text-transform:uppercase;
    color:var(--ink-2);font-weight:600;
  }
  .social-card .s-handle{
    font-family:'Mona Sans',sans-serif;font-weight:800;
    font-size:clamp(15px,1.15vw,18px);letter-spacing:-0.01em;line-height:1.1;
    color:var(--ink);word-break:break-word;
  }
  .social-card .s-count{
    font-size:13px;color:var(--ink-2);
    display:flex;justify-content:space-between;align-items:center;
    font-variant-numeric:tabular-nums;
    padding-top:12px;border-top:1px solid var(--line);
  }
  .social-card .s-count strong{color:var(--ink);font-weight:700}
  .social-card .s-arrow{
    color:var(--accent-mc);font-weight:700;font-size:16px;
    transition:transform .15s;
  }
  .social-card:hover .s-arrow{transform:translateX(3px)}
  @media (max-width:900px){
    .profile-grid{grid-template-columns:1fr;gap:36px}
    .profile-photo{max-width:360px}
  }
  @media (max-width:640px){
    .social-grid{grid-template-columns:1fr;gap:10px}
  }

  /* ============================== Contexto ============================== */
  .contexto-body{
    display:grid;
    grid-template-columns:minmax(0,0.36fr) minmax(0,1fr);
    gap:clamp(40px,5vw,96px);
  }
  .contexto-body .rail{padding-top:8px}
  .contexto-body p{
    font-size:clamp(17px,1.25vw,20px);line-height:1.6;color:var(--ink);
    margin:0 0 24px;max-width:60ch;
  }
  .contexto-body p:last-of-type{color:var(--ink-2)}
  .contexto-body .pull{
    margin-top:32px;padding:24px 0;border-top:1px solid var(--line);
    font-family:'Cormorant Garamond',serif;font-style:italic;
    font-size:clamp(22px,2vw,28px);line-height:1.35;color:var(--accent);
    max-width:38ch;
  }
  @media (max-width:900px){.contexto-body{grid-template-columns:1fr;gap:32px}}

  /* ============================== Alcance ============================== */
  .practice-grid{
    display:grid;
    grid-template-columns:minmax(0,0.36fr) minmax(0,1fr);
    gap:clamp(40px,5vw,96px);
  }
  .practice-grid .rail{padding-top:8px}
  .practice-list{border-top:1px solid var(--line-strong)}
  .practice{
    display:grid;
    grid-template-columns:60px minmax(0,0.32fr) minmax(0,1fr);
    gap:clamp(24px,3vw,56px);
    padding-block:clamp(36px,5vh,52px);
    border-bottom:1px solid var(--line);
    align-items:baseline;
  }
  .practice:last-child{border-bottom:0}
  .practice .num{
    font-family:'Mona Sans',sans-serif;font-weight:800;font-style:italic;
    font-size:clamp(22px,1.6vw,26px);color:var(--accent-mc);
    letter-spacing:-0.02em;line-height:1;
  }
  .practice .name{
    font-family:'Mona Sans',sans-serif;font-weight:800;
    font-size:clamp(22px,2vw,30px);letter-spacing:-0.015em;line-height:1.1;
  }
  .practice .desc{
    font-size:clamp(15px,1.1vw,17px);color:var(--ink-2);line-height:1.6;max-width:58ch;
  }
  .practice .verb{color:var(--accent);font-weight:500}
  @media (max-width:780px){
    .practice-grid{grid-template-columns:1fr;gap:32px}
    .practice{grid-template-columns:40px 1fr;gap:12px 20px}
    .practice .desc{grid-column:1 / -1;padding-left:60px}
  }

  /* ============================== Cómo trabajamos (dark) ============================== */
  .invert{
    background:var(--invert-section);color:var(--invert-ink);border-color:transparent;
  }
  .invert .section-head h2{color:var(--invert-ink)}
  .invert .lead{color:var(--invert-ink-2)}
  .invert .smallcaps-accent{color:var(--invert-accent)}
  .invert .smallcaps-accent::before{background:var(--invert-accent)}
  .invert .smallcaps{color:var(--invert-ink-2)}
  .phases{
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr));
    gap:clamp(24px,3vw,56px);
    padding-top:clamp(40px,6vh,72px);
    border-top:1px solid var(--invert-line);
  }
  .phase{
    display:flex;flex-direction:column;gap:20px;padding-right:clamp(0px,1.5vw,32px);
  }
  .phase + .phase{
    border-left:1px solid var(--invert-line);
    padding-left:clamp(20px,2vw,40px);
  }
  .phase .num{
    font-family:'Mona Sans',sans-serif;font-weight:800;font-style:italic;
    font-size:clamp(36px,3.6vw,56px);color:var(--invert-line);
    letter-spacing:-0.03em;line-height:1;
  }
  .phase .pname{
    font-family:'Mona Sans',sans-serif;font-weight:800;
    font-size:clamp(19px,1.5vw,24px);letter-spacing:-0.01em;line-height:1.15;color:var(--invert-ink);
  }
  .phase .pmonths{
    font-size:12px;letter-spacing:0.14em;text-transform:uppercase;
    color:var(--invert-accent);font-weight:600;
  }
  .phase .pdesc{
    font-size:14.5px;line-height:1.55;color:var(--invert-ink-2);
  }
  .phase .pline{width:28px;height:2px;background:var(--invert-accent);margin-top:4px}
  @media (max-width:1000px){
    .phases{grid-template-columns:repeat(2,1fr);gap:48px}
    .phase + .phase{border-left:0;padding-left:0}
    .phase:nth-child(2n)+.phase{border-top:1px solid var(--invert-line);padding-top:40px}
  }
  @media (max-width:600px){
    .phases{grid-template-columns:1fr}
    .phase + .phase{border-top:1px solid var(--invert-line);padding-top:32px}
  }

  /* ============================== Cronograma ============================== */
  .tramos{border-top:1px solid var(--line-strong)}
  .tramo{
    display:grid;
    grid-template-columns:minmax(0,0.28fr) minmax(0,0.3fr) minmax(0,1fr);
    gap:clamp(24px,3vw,56px);
    padding-block:clamp(36px,5vh,52px);
    border-bottom:1px solid var(--line);
    align-items:start;
  }
  .tramo:last-child{border-bottom:0}
  .tramo .tramo-label{
    font-size:12px;letter-spacing:0.14em;text-transform:uppercase;
    font-weight:600;color:var(--accent-mc);
  }
  .tramo .tramo-months{
    font-family:'Mona Sans',sans-serif;font-weight:800;
    font-size:clamp(24px,2.2vw,32px);letter-spacing:-0.015em;line-height:1.1;
    color:var(--ink);margin-top:6px;
  }
  .tramo .tramo-name{
    font-family:'Mona Sans',sans-serif;font-weight:800;
    font-size:clamp(22px,1.8vw,28px);letter-spacing:-0.015em;line-height:1.15;
    color:var(--ink);
  }
  .tramo .tramo-window{
    font-size:13px;color:var(--ink-3);margin-top:6px;letter-spacing:0.02em;
  }
  .tramo .tramo-body{color:var(--ink-2);font-size:15px;line-height:1.6;max-width:56ch}
  .tramo .tramo-body ul{margin:0;padding-left:20px}
  .tramo .tramo-body li{margin-bottom:6px}
  .tramo .tramo-body li strong{color:var(--ink);font-weight:600}
  @media (max-width:900px){.tramo{grid-template-columns:1fr;gap:16px}}

  /* ============================== Inversión ============================== */
  .money-grid{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:clamp(16px,2vw,32px);
    margin-bottom:clamp(56px,7vh,88px);
  }
  .money{
    background:var(--paper-2);
    padding:clamp(28px,3vw,44px);
    display:flex;flex-direction:column;gap:20px;
    border-top:3px solid var(--accent);
    position:relative;
  }
