  /* ============================== Print (Guardar como PDF) ============================== */
  @page{
    size: A4 portrait;
    margin: 16mm 14mm 18mm 14mm;
  }
  @media print{
    /* Fuerza tema claro para el PDF */
    :root{
      --paper:#FFFFFF; --paper-2:#F5F2EB;
      --ink:#141414; --ink-2:rgba(20,20,20,0.72); --ink-3:rgba(20,20,20,0.5);
      --ink-4:rgba(20,20,20,0.18);
      --line:rgba(20,20,20,0.15); --line-strong:rgba(20,20,20,0.35);
      --accent:#1E4438; --accent-mc:#F26522;
      --field:rgba(20,20,20,0.04);
      --logo-filter:none;
    }
    *{
      -webkit-print-color-adjust:exact !important;
      print-color-adjust:exact !important;
      transition:none !important; animation:none !important;
    }
    html,body{
      background:#FFFFFF !important; color:#141414 !important;
      font-size:10pt; line-height:1.5;
    }
    a{color:inherit !important;text-decoration:none !important}
    a[href^="http"]::after,
    a[href^="mailto"]::after,
    a[href^="wa.me"]::after{content:"" !important}

    /* ---- Ocultar controles interactivos ---- */
    .topbar nav, .hero-meta, .cta-actions, .btn-cta,
    .foot-social, .foot-bottom, .hero-mark{
      display:none !important;
    }

    /* ---- Reset del shell y del topbar para papel ---- */
    .shell{padding:0 !important; max-width:none}
    .topbar{
      position:static !important;
      padding:0 0 5mm 0 !important;
      border-bottom:1px solid var(--line) !important;
      backdrop-filter:none !important;
      background:transparent !important;
    }
    .topbar-inner{padding-block:0 !important}

    /* ---- Padding uniforme por sección ---- */
    section, .about-quote, .cta-block{
      padding:6mm 0 !important; border-bottom:1px solid var(--line);
    }
    footer{padding:6mm 0 4mm 0 !important; border-top:1px solid var(--line)}

    /* ---- Saltos de página ---- */
    #alcance, #metodo, #cronograma, #inversion, #cierre{
      page-break-before:always; break-before:page;
    }
    .practice, .phase, .tramo, .money, .term, .social-card,
    .profile-photo, .cover-meta > div, .about-head, .money-total,
    .foot-cols{
      page-break-inside:avoid; break-inside:avoid;
    }
    h1, h2, h3, h4, h5, .section-head{
      page-break-after:avoid; break-after:avoid;
    }
    p{orphans:3; widows:3}

    /* ---- Tipografía en puntos (escala de imprenta) ---- */
    .hero-title{font-size:30pt !important; line-height:1.02 !important; max-width:none}
    .hero-eyebrow{margin-bottom:5mm !important}
    .hero-sub{font-size:11pt !important; margin-top:4mm !important; max-width:none}
    .cta-title{font-size:22pt !important; line-height:1.1 !important; max-width:none}
    .section-head h2{font-size:18pt !important; line-height:1.1 !important; margin-bottom:3mm !important; max-width:none}
    .about-head h3{font-size:14pt !important; line-height:1.3 !important; max-width:none}
    #perfil-title{font-size:22pt !important}
    .lead{font-size:10pt !important; max-width:none}

    /* ---- Section head layout en print ---- */
    .section-head{
      grid-template-columns:minmax(0,0.25fr) minmax(0,1fr) !important;
      gap:6mm !important;
      margin-bottom:6mm !important;
    }

    /* ---- Hero ---- */
    .hero{padding:4mm 0 8mm 0 !important}
    .hero-grid{grid-template-columns:1fr !important; gap:0 !important}
    .cover-meta{
      margin-top:8mm !important;
      padding-top:4mm !important;
      gap:4mm !important;
      grid-template-columns:repeat(4,1fr) !important;
    }
    .cover-meta dt{font-size:7pt !important}
    .cover-meta dd{font-size:10pt !important; line-height:1.25}

    /* ---- Sobre esta propuesta ---- */
    .about-quote{padding:6mm 0 !important}
    .about-head{gap:4mm !important; margin-bottom:0 !important}

    /* ---- Perfil ---- */
    .profile-grid{
      grid-template-columns:52mm 1fr !important;
      gap:8mm !important;
    }
    .profile-photo{
      max-width:52mm !important;
      aspect-ratio:1080/1350 !important;
      border-top:2pt solid var(--accent-mc) !important;
    }
    .profile-photo figcaption{
      padding:6pt 8pt !important; font-size:7pt !important;
      background:linear-gradient(to top,rgba(21,20,15,0.72),rgba(21,20,15,0)) !important;
    }
    .profile-body p{
      font-size:10pt !important; margin-bottom:3mm !important; max-width:none !important;
    }
    .profile-social-head{
      margin-top:5mm !important; padding-top:3mm !important; margin-bottom:3mm !important;
    }
    .social-grid{gap:3mm !important}
    .social-card{padding:3mm !important; gap:2mm !important}
    .social-card .s-icon{width:12pt !important; height:12pt !important}
    .social-card .s-net{font-size:7pt !important}
    .social-card .s-handle{font-size:11pt !important}
    .social-card .s-count{font-size:9pt !important; padding-top:2mm !important}
    .social-card .s-arrow{font-size:11pt !important}

    /* ---- Contexto ---- */
    .contexto-body{grid-template-columns:minmax(0,0.25fr) minmax(0,1fr) !important; gap:6mm !important}
    .contexto-body p{font-size:11pt !important; margin-bottom:3mm !important; max-width:none !important}
    .contexto-body .pull{
      font-size:14pt !important; padding:3mm 0 !important; margin-top:4mm !important;
    }

    /* ---- Alcance (prácticas) ---- */
    .practice-grid{grid-template-columns:minmax(0,0.25fr) minmax(0,1fr) !important; gap:6mm !important}
    .practice{
      padding-block:3mm !important; gap:5mm !important;
      grid-template-columns:24pt minmax(0,0.32fr) minmax(0,1fr) !important;
    }
    .practice .num{font-size:11pt !important}
    .practice .name{font-size:13pt !important}
    .practice .desc{font-size:10pt !important; max-width:none !important; line-height:1.5}

    /* ---- Método (dark → light en print para ahorrar tinta) ---- */
    .invert{background:#FFFFFF !important; color:#141414 !important}
    .invert .section-head h2{color:#141414 !important}
    .invert .lead{color:rgba(20,20,20,0.7) !important}
    .invert .smallcaps-accent{color:var(--accent-mc) !important}
    .invert .smallcaps-accent::before{background:var(--accent-mc) !important}
    .invert .phases{
      border-top:1px solid var(--line) !important;
      padding-top:5mm !important; gap:5mm !important;
    }
    .invert .phase + .phase{
      border-left:1px solid var(--line) !important; padding-left:4mm !important;
    }
    .invert .phase .num{
      color:rgba(20,20,20,0.22) !important; font-size:22pt !important;
    }
    .invert .phase .pname{color:#141414 !important; font-size:12pt !important}
    .invert .phase .pdesc{color:rgba(20,20,20,0.7) !important; font-size:9pt !important}
    .invert .phase .pmonths{color:var(--accent-mc) !important; font-size:8pt !important}
    .invert .phase .pline{background:var(--accent-mc) !important; width:20pt !important}
    .invert .phase{gap:2mm !important}

    /* ---- Cronograma ---- */
    .tramo{
      padding-block:4mm !important; gap:5mm !important;
      grid-template-columns:minmax(0,0.26fr) minmax(0,0.3fr) minmax(0,1fr) !important;
    }
    .tramo .tramo-label{font-size:8pt !important}
    .tramo .tramo-months{font-size:15pt !important; margin-top:3pt !important}
    .tramo .tramo-name{font-size:12pt !important}
    .tramo .tramo-window{font-size:9pt !important; margin-top:3pt !important}
    .tramo .tramo-body{font-size:10pt !important; max-width:none !important; line-height:1.5}
    .tramo .tramo-body li{margin-bottom:3pt !important}

    /* ---- Inversión ---- */
    .money-grid{
      gap:3mm !important; margin-bottom:6mm !important;
      grid-template-columns:repeat(3,1fr) !important;
    }
    .money{padding:4mm !important; gap:2mm !important}
    .money .m-label{font-size:7pt !important}
    .money .m-title{font-size:11pt !important}
    .money .m-months{font-size:8pt !important}
    .money .m-badge{padding:2pt 5pt !important; font-size:7pt !important}
    .money .m-price{font-size:18pt !important; line-height:0.95 !important}
    .money .m-strike{font-size:9pt !important; margin-bottom:2pt !important}
    .money .m-price small{font-size:7.5pt !important; margin-top:2mm !important}
    .money .m-list{
      padding-top:3mm !important; gap:2pt !important; font-size:8.5pt !important;
    }
    .money .m-list li::before{top:5pt !important}
    .money-total{
      padding-top:5mm !important; gap:6mm !important;
      grid-template-columns:minmax(0,1fr) minmax(0,0.55fr) !important;
    }
    .money-total .t-label{font-size:9pt !important}
    .money-total .t-price{font-size:28pt !important}
    .money-total .t-saved{font-size:8pt !important; margin-top:3pt !important}
    .money-total .t-note{font-size:8.5pt !important; margin-top:2mm !important; max-width:none !important}
    .terms{
      margin-top:6mm !important; gap:3mm 6mm !important;
      grid-template-columns:repeat(2,1fr) !important;
    }
    .term{padding-top:3mm !important}
    .term dt{font-size:7pt !important; margin-bottom:3pt !important}
    .term dd{font-size:9.5pt !important; line-height:1.45}

    /* ---- Cierre / CTA ---- */
    .cta-block{padding:10mm 0 !important}
    .cta-center{gap:0}
    .cta-sub{font-size:11pt !important; margin:4mm 0 0 0 !important; max-width:none !important}

    /* ---- Footer ---- */
    footer .foot-brand .foot-mark{display:none !important}
    .foot-cols{
      gap:6mm !important; padding-top:4mm !important;
      grid-template-columns:1.3fr 1fr 1fr 1fr !important;
    }
    .foot-brand{grid-template-columns:1fr !important; gap:2mm !important}
    .foot-brand .desc{font-size:8.5pt !important; margin-bottom:3mm !important; max-width:none}
    .foot-col h5{font-size:8pt !important; margin-bottom:3mm !important}
    .foot-col a{font-size:8.5pt !important}
    .foot-col ul{gap:2mm !important}
    .foot-tagline{
      margin-top:4mm !important; padding-top:3mm !important;
      flex-direction:row !important; align-items:baseline !important;
    }
    .foot-tagline .left{font-size:7.5pt !important; max-width:36ch}
    .foot-tagline .right{font-size:12pt !important}
  }
</style>
</head>
